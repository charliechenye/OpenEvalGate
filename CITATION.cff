title: "OpenEvalGate: Evidence-backed launch readiness for production AI assistants and agents"
type: software
authors:
  - family-names: Zhu
    given-names: Chenye
    alias: Charlie Zhu
version: 0.1.0
license: MIT
repository-code: "https://github.com/charliechenye/OpenEvalGate"
