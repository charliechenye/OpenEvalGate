{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/charliechenye/OpenEvalGate/schemas/eval-run-artifact-index-v1.schema.json",
  "title": "OpenEvalGate Eval-Run Artifact Index v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "artifacts"],
  "properties": {
    "schema_version": {
      "const": "1"
    },
    "run_id": {
      "$ref": "#/$defs/identifier"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "extensions": {
      "type": "object"
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_type",
        "run_id",
        "case_id",
        "candidate_id",
        "candidate_version",
        "evaluator_id",
        "path",
        "digest"
      ],
      "properties": {
        "artifact_type": {
          "$ref": "#/$defs/identifier"
        },
        "run_id": {
          "$ref": "#/$defs/identifier"
        },
        "case_id": {
          "$ref": "#/$defs/identifier"
        },
        "trial_id": {
          "$ref": "#/$defs/identifier"
        },
        "candidate_id": {
          "$ref": "#/$defs/identifier"
        },
        "candidate_version": {
          "$ref": "#/$defs/identifier"
        },
        "evaluator_id": {
          "$ref": "#/$defs/identifier"
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "^(?:/|[A-Za-z]:[\\\\/])"
          }
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        },
        "digest": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sha256"],
          "properties": {
            "sha256": {
              "$ref": "#/$defs/sha256"
            }
          }
        },
        "annotations": {
          "type": "object"
        }
      }
    }
  }
}
