{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/charliechenye/OpenEvalGate/schemas/eval-run-manifest-v1.schema.json",
  "title": "OpenEvalGate Eval-Run Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run",
    "candidate",
    "evaluation",
    "outputs"
  ],
  "properties": {
    "schema_version": {
      "const": "1"
    },
    "run": {
      "$ref": "#/$defs/run"
    },
    "candidate": {
      "$ref": "#/$defs/candidate"
    },
    "producer": {
      "$ref": "#/$defs/versionedIdentity"
    },
    "evaluation": {
      "$ref": "#/$defs/evaluation"
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/namedResourceDescriptor"
      }
    },
    "outputs": {
      "$ref": "#/$defs/outputs"
    },
    "extensions": {
      "type": "object"
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^\\S(?:[^\\r\\n]*\\S)?$"
    },
    "alias": {
      "type": "string",
      "pattern": "^\\S(?:[^\\r\\n]*\\S)?$"
    },
    "aliases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/alias"
      },
      "uniqueItems": true
    },
    "mediaType": {
      "type": "string",
      "pattern": "^[^\\r\\n]+$"
    },
    "relativePath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*//)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)(?![A-Za-z]:)\\S(?:[^\\r\\n]*[^\\s/])?$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "digest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sha256"
      ],
      "properties": {
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "fileDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        },
        "extensions": {
          "type": "object"
        }
      },
      "anyOf": [
        {
          "required": [
            "path"
          ]
        },
        {
          "required": [
            "uri"
          ]
        }
      ]
    },
    "resultsDescriptor": {
      "allOf": [
        {
          "$ref": "#/$defs/fileDescriptor"
        },
        {
          "required": [
            "path"
          ]
        }
      ]
    },
    "knownSingletonRole": {
      "enum": [
        "eval_cases",
        "evaluation_policy",
        "review_policy",
        "routing_policy",
        "escalation_contract",
        "action_risk_matrix"
      ]
    },
    "namedResourceDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role"
      ],
      "properties": {
        "role": {
          "$ref": "#/$defs/identifier"
        },
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        },
        "extensions": {
          "type": "object"
        }
      },
      "allOf": [
        {
          "anyOf": [
            {
              "required": [
                "path"
              ]
            },
            {
              "required": [
                "uri"
              ]
            }
          ]
        },
        {
          "if": {
            "required": [
              "role"
            ],
            "properties": {
              "role": {
                "not": {
                  "enum": [
                    "eval_cases",
                    "evaluation_policy",
                    "review_policy",
                    "routing_policy",
                    "escalation_contract",
                    "action_risk_matrix"
                  ]
                }
              }
            }
          },
          "then": {
            "required": [
              "name"
            ]
          }
        }
      ]
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "status"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "status": {
          "enum": [
            "complete",
            "failed",
            "aborted"
          ]
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        },
        "extensions": {
          "type": "object"
        }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "$ref": "#/$defs/identifier"
        },
        "accepted_aliases": {
          "$ref": "#/$defs/aliases"
        },
        "artifact": {
          "$ref": "#/$defs/fileDescriptor"
        },
        "annotations": {
          "type": "object"
        },
        "extensions": {
          "type": "object"
        }
      }
    },
    "versionedIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "$ref": "#/$defs/identifier"
        },
        "extensions": {
          "type": "object"
        }
      }
    },
    "humanEvaluator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "role": {
          "$ref": "#/$defs/identifier"
        },
        "accepted_aliases": {
          "$ref": "#/$defs/aliases"
        },
        "configuration": {
          "$ref": "#/$defs/fileDescriptor"
        },
        "extensions": {
          "type": "object"
        }
      }
    },
    "deterministicEvaluator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "$ref": "#/$defs/identifier"
        },
        "accepted_aliases": {
          "$ref": "#/$defs/aliases"
        },
        "configuration": {
          "$ref": "#/$defs/fileDescriptor"
        },
        "extensions": {
          "type": "object"
        }
      }
    },
    "modelJudgeEvaluator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "$ref": "#/$defs/identifier"
        },
        "accepted_aliases": {
          "$ref": "#/$defs/aliases"
        },
        "configuration": {
          "$ref": "#/$defs/fileDescriptor"
        },
        "extensions": {
          "type": "object"
        }
      }
    },
    "humanComponentEvaluator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "kind": {
          "const": "human"
        },
        "configuration": {
          "$ref": "#/$defs/fileDescriptor"
        },
        "extensions": {
          "type": "object"
        }
      }
    },
    "deterministicComponentEvaluator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "version"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "kind": {
          "const": "deterministic"
        },
        "version": {
          "$ref": "#/$defs/identifier"
        },
        "configuration": {
          "$ref": "#/$defs/fileDescriptor"
        },
        "extensions": {
          "type": "object"
        }
      }
    },
    "modelJudgeComponentEvaluator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "version"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "kind": {
          "const": "model_judge"
        },
        "version": {
          "$ref": "#/$defs/identifier"
        },
        "configuration": {
          "$ref": "#/$defs/fileDescriptor"
        },
        "extensions": {
          "type": "object"
        }
      }
    },
    "hybridEvaluator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "components",
        "decision_policy"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "accepted_aliases": {
          "$ref": "#/$defs/aliases"
        },
        "components": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              {
                "$ref": "#/$defs/humanComponentEvaluator"
              },
              {
                "$ref": "#/$defs/deterministicComponentEvaluator"
              },
              {
                "$ref": "#/$defs/modelJudgeComponentEvaluator"
              }
            ]
          }
        },
        "decision_policy": {
          "$ref": "#/$defs/fileDescriptor"
        },
        "extensions": {
          "type": "object"
        }
      }
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "evaluator"
      ],
      "properties": {
        "kind": {
          "enum": [
            "human",
            "deterministic",
            "model_judge",
            "hybrid"
          ]
        },
        "framework": {
          "$ref": "#/$defs/versionedIdentity"
        },
        "evaluator": true,
        "policy": {
          "$ref": "#/$defs/fileDescriptor"
        },
        "extensions": {
          "type": "object"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "human"
              }
            }
          },
          "then": {
            "properties": {
              "evaluator": {
                "$ref": "#/$defs/humanEvaluator"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "deterministic"
              }
            }
          },
          "then": {
            "properties": {
              "evaluator": {
                "$ref": "#/$defs/deterministicEvaluator"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "model_judge"
              }
            }
          },
          "then": {
            "properties": {
              "evaluator": {
                "$ref": "#/$defs/modelJudgeEvaluator"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "hybrid"
              }
            }
          },
          "then": {
            "properties": {
              "evaluator": {
                "$ref": "#/$defs/hybridEvaluator"
              }
            }
          }
        }
      ]
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "results"
      ],
      "properties": {
        "results": {
          "$ref": "#/$defs/resultsDescriptor"
        },
        "artifact_index": {
          "$ref": "#/$defs/fileDescriptor"
        },
        "additional": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/fileDescriptor"
          }
        },
        "extensions": {
          "type": "object"
        }
      }
    }
  }
}
