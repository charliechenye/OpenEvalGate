{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/charliechenye/OpenEvalGate/schemas/eval-run-review-context-v1.schema.json",
  "title": "OpenEvalGate Eval-Run Review Context v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "candidate"
  ],
  "properties": {
    "schema_version": {
      "const": "1"
    },
    "candidate": {
      "$ref": "#/$defs/candidate"
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/namedResourceDescriptor"
      }
    },
    "recency_policy": {
      "$ref": "#/$defs/recencyPolicy"
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "extensions": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "required": [
          "recency_policy"
        ]
      },
      "then": {
        "required": [
          "observed_at"
        ]
      }
    }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^\\S(?:[^\\r\\n]*\\S)?$"
    },
    "alias": {
      "type": "string",
      "pattern": "^\\S(?:[^\\r\\n]*\\S)?$"
    },
    "aliases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/alias"
      },
      "uniqueItems": true
    },
    "mediaType": {
      "type": "string",
      "pattern": "^[^\\r\\n]+$"
    },
    "relativePath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*//)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)(?![A-Za-z]:)\\S(?:[^\\r\\n]*[^\\s/])?$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "digest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sha256"
      ],
      "properties": {
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "fileDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        },
        "extensions": {
          "type": "object"
        }
      },
      "anyOf": [
        {
          "required": [
            "path"
          ]
        },
        {
          "required": [
            "uri"
          ]
        }
      ]
    },
    "knownSingletonRole": {
      "enum": [
        "eval_cases",
        "evaluation_policy",
        "review_policy",
        "routing_policy",
        "escalation_contract",
        "action_risk_matrix"
      ]
    },
    "namedResourceDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role"
      ],
      "properties": {
        "role": {
          "$ref": "#/$defs/identifier"
        },
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        },
        "extensions": {
          "type": "object"
        }
      },
      "allOf": [
        {
          "anyOf": [
            {
              "required": [
                "path"
              ]
            },
            {
              "required": [
                "uri"
              ]
            }
          ]
        },
        {
          "if": {
            "required": [
              "role"
            ],
            "properties": {
              "role": {
                "not": {
                  "enum": [
                    "eval_cases",
                    "evaluation_policy",
                    "review_policy",
                    "routing_policy",
                    "escalation_contract",
                    "action_risk_matrix"
                  ]
                }
              }
            }
          },
          "then": {
            "required": [
              "name"
            ]
          }
        }
      ]
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "$ref": "#/$defs/identifier"
        },
        "artifact": {
          "$ref": "#/$defs/fileDescriptor"
        },
        "extensions": {
          "type": "object"
        }
      }
    },
    "recencyPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_age_days",
        "max_future_clock_skew_seconds"
      ],
      "properties": {
        "max_age_days": {
          "type": "integer",
          "minimum": 0
        },
        "max_future_clock_skew_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "extensions": {
          "type": "object"
        }
      }
    }
  }
}
